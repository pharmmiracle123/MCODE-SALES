<script>
/* ==============================
   FIREBASE INIT
============================== */
const firebaseConfig = {
  apiKey: "AIzaSyDC49oGcE3EAXSjjJ1mstpowbpjaaY8PTc",
  authDomain: "mcode-sales.firebaseapp.com",
  projectId: "mcode-sales",
  databaseURL: "https://mcode-sales-default-rtdb.firebaseio.com",
  storageBucket: "mcode-sales.appspot.com",
  messagingSenderId: "823876737976",
  appId: "1:823876737976:web:45245a0fef4f5094dd0d4d"
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const db = firebase.database();
auth.setPersistence(firebase.auth.Auth.Persistence.LOCAL);

/* ==============================
   EMAILJS INIT — put your own keys here
============================== */
emailjs.init("YOUR_EMAILJS_PUBLIC_KEY");
const EMAILJS_SERVICE_ID = "YOUR_SERVICE_ID";
const EMAILJS_TEMPLATE_ID = "YOUR_TEMPLATE_ID";

/* =====================================================
   APP STATE
===================================================== */
let userUID = null;
let clientCompanyName = "My Company";
let productData = [];
let cart = [];
let soldData = [];
let adminPinHash = null;      // SHA-256 hash of the admin PIN, stored per account
let resetCodeHash = null;     // SHA-256 hash of the temporary reset code
let resetCodeExpiry = null;   // timestamp
let pinFlowState = null;      // 'create' | 'enter' | 'resetCodeEntry' | 'newPinAfterReset' | 'changePin_verify' | 'changePin_new'
let pendingAdminAction = null;

/* ==============================
   TOAST NOTIFICATIONS
============================== */
function toast(msg, isError=false){
  const container = document.getElementById('toastContainer');
  const el = document.createElement('div');
  el.className = `toast-fade ${isError?'bg-red-600':'bg-gray-900'} text-white px-4 py-2 rounded-lg shadow-lg text-sm`;
  el.innerText = msg;
  container.appendChild(el);
  setTimeout(()=>{ el.style.opacity='0'; setTimeout(()=>el.remove(),300); }, 2600);
}

/* ==============================
   HASHING HELPER
============================== */
async function hashPin(pin){
  const enc = new TextEncoder().encode(pin);
  const buf = await crypto.subtle.digest('SHA-256', enc);
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

/* ==============================
   AUTH HANDLER
============================== */
auth.onAuthStateChanged(async user => {
  if (user) {
    userUID = user.uid;
    document.getElementById("userEmail").innerText = user.email;
    setAuthIcon(true);
    await loadFromFirebase();
    renderProducts();
    updateCartUI();
    document.getElementById('loadingOverlay').style.display = 'none';

    window.addEventListener("hashchange", () => {
      if (location.hash === "#admin") {
        openAdmin({preventDefault(){}});
      }
    });
  } else {
    disableAdmin();
    setAuthIcon(false);
    document.getElementById('loadingOverlay').style.display = 'none';
    window.location.href = "firebase login.html";
  }
});

/* ==============================
   ADMIN PIN MODAL CONTROLLER
============================== */
const pinModal = document.getElementById('pinModal');
const pinModalTitle = document.getElementById('pinModalTitle');
const pinModalSubtitle = document.getElementById('pinModalSubtitle');
const pinInput1 = document.getElementById('pinInput1');
const pinInput2 = document.getElementById('pinInput2');
const pinError = document.getElementById('pinError');
const pinForgotBtn = document.getElementById('pinForgotBtn');
const pinSubmitBtn = document.getElementById('pinSubmitBtn');
const pinCancelBtn = document.getElementById('pinCancelBtn');

function showPinModal(mode){
  pinFlowState = mode;
  pinError.classList.add('hidden');
  pinInput1.value = ''; pinInput2.value = '';
  pinInput2.classList.add('hidden-modal');
  pinForgotBtn.classList.add('hidden-modal');

  if(mode === 'create'){
    pinModalTitle.innerText = 'Create Your Admin PIN';
    pinModalSubtitle.innerText = 'Set a private 4–6 digit PIN to protect admin access. Only you (or staff you trust) should know it.';
    pinInput2.classList.remove('hidden-modal');
  } else if(mode === 'enter'){
    pinModalTitle.innerText = 'Admin Access';
    pinModalSubtitle.innerText = 'Enter your admin PIN to continue.';
    pinForgotBtn.classList.remove('hidden-modal');
  } else if(mode === 'changePin_verify'){
    pinModalTitle.innerText = 'Verify Current PIN';
    pinModalSubtitle.innerText = 'Enter your current admin PIN to change it.';
  } else if(mode === 'changePin_new' || mode === 'newPinAfterReset'){
    pinModalTitle.innerText = 'Set New Admin PIN';
    pinModalSubtitle.innerText = 'Choose a new 4–6 digit PIN.';
    pinInput2.classList.remove('hidden-modal');
  } else if(mode === 'resetCodeEntry'){
    pinModalTitle.innerText = 'Enter Reset Code';
    pinModalSubtitle.innerText = `We sent a 6-digit code to ${auth.currentUser?.email || 'your email'}. It expires in 10 minutes.`;
  }

  pinModal.style.display = 'flex';
  setTimeout(()=>pinInput1.focus(), 50);
}

function closePinModal(){
  pinModal.style.display = 'none';
}

pinCancelBtn.onclick = () => { closePinModal(); pendingAdminAction = null; };

pinSubmitBtn.onclick = async () => {
  const val1 = pinInput1.value.trim();
  const val2 = pinInput2.value.trim();

  function showErr(msg){ pinError.innerText = msg; pinError.classList.remove('hidden'); }

  if(pinFlowState === 'create' || pinFlowState === 'newPinAfterReset' || pinFlowState === 'changePin_new'){
    if(!/^\d{4,6}$/.test(val1)) return showErr('PIN must be 4–6 digits.');
    if(val1 !== val2) return showErr('PINs do not match.');
    adminPinHash = await hashPin(val1);
    resetCodeHash = null; resetCodeExpiry = null;
    await saveToFirebase();
    closePinModal();
    sessionStorage.setItem('isAdmin', 'true');
    toast(pinFlowState === 'create' ? 'Admin PIN created.' : 'Admin PIN updated.');
    if(pendingAdminAction){ const fn = pendingAdminAction; pendingAdminAction = null; fn(); }
    else enableAdmin();
    return;
  }

  if(pinFlowState === 'enter'){
    if(!adminPinHash) return showErr('No PIN set yet.');
    const hash = await hashPin(val1);
    if(hash !== adminPinHash) return showErr('Incorrect PIN.');
    sessionStorage.setItem('isAdmin', 'true');
    closePinModal();
    if(pendingAdminAction){ const fn = pendingAdminAction; pendingAdminAction = null; fn(); }
    else enableAdmin();
    return;
  }

  if(pinFlowState === 'changePin_verify'){
    const hash = await hashPin(val1);
    if(hash !== adminPinHash) return showErr('Incorrect PIN.');
    showPinModal('changePin_new');
    return;
  }

  if(pinFlowState === 'resetCodeEntry'){
    if(!resetCodeHash || !resetCodeExpiry || Date.now() > resetCodeExpiry){
      return showErr('Code expired. Please request a new one.');
    }
    const hash = await hashPin(val1);
    if(hash !== resetCodeHash) return showErr('Incorrect code.');
    showPinModal('newPinAfterReset');
    return;
  }
};

pinForgotBtn.onclick = async () => {
  const email = auth.currentUser?.email;
  if(!email) return toast('No account email on file.', true);
  if(!confirm(`Send a PIN reset code to ${email}?`)) return;

  const code = Math.floor(100000 + Math.random()*900000).toString();
  resetCodeHash = await hashPin(code);
  resetCodeExpiry = Date.now() + 10*60*1000;
  await saveToFirebase();

  try {
    await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
      to_email: email,
      reset_code: code,
      company_name: clientCompanyName
    });
    toast('Reset code sent to your email.');
    showPinModal('resetCodeEntry');
  } catch(err){
    console.error(err);
    toast('Could not send email. Check EmailJS setup.', true);
  }
};

/* ==============================
   ADMIN OPEN / CLOSE
============================== */
function openAdmin(e){
  e.preventDefault();
  location.hash = '#admin';
  if(sessionStorage.getItem('isAdmin') === 'true'){
    enableAdmin();
    return;
  }
  if(adminPinHash){
    showPinModal('enter');
  } else {
    showPinModal('create');
  }
}

function enableAdmin(){
  document.getElementById('admin').classList.remove('hidden');
  renderAdminProducts();
}

function disableAdmin(){
  sessionStorage.removeItem('isAdmin');
  document.getElementById('admin').classList.add('hidden');
}

/* ==============================
   COMPANY NAME (admin-gated)
============================== */
function handleCompanyNameClick(){
  if(sessionStorage.getItem('isAdmin') === 'true'){
    openCompanyModal();
  } else {
    pendingAdminAction = openCompanyModal;
    if(adminPinHash) showPinModal('enter'); else showPinModal('create');
  }
}

function openCompanyModal(){
  document.getElementById('companyNameInput').value = clientCompanyName;
  document.getElementById('companyModal').style.display = 'flex';
}
document.getElementById('companyCancelBtn').onclick = () => document.getElementById('companyModal').style.display = 'none';
document.getElementById('companySaveBtn').onclick = async () => {
  const name = document.getElementById('companyNameInput').value.trim();
  if(!name) return toast('Company name cannot be empty.', true);
  clientCompanyName = name;
  document.getElementById('companyName').innerText = clientCompanyName;
  document.getElementById('companyModal').style.display = 'none';
  await saveToFirebase();
  toast('Company name updated.');
};

/* ==============================
   HISTORY
============================== */
function toggleHistory(){
  const history = document.getElementById("history");
  history.classList.toggle("hidden");
  renderHistory();
}
function renderHistory() {
  const list = document.getElementById("historyList");
  list.innerHTML = "";

  if (soldData.length === 0) {
    list.innerHTML = "<p class='text-gray-600'>No sales yet</p>";
    return;
  }

  const grouped = soldData.reduce((acc, s) => {
    acc[s.date] = acc[s.date] || [];
    acc[s.date].push(s);
    return acc;
  }, {});

  for (const date in grouped) {
    list.innerHTML += `<h3 class="font-bold mt-4 mb-2 text-lg">${date}</h3>`;
    grouped[date].forEach((s, i) => {
      list.innerHTML += `
        <div class="bg-gray-100 p-3 rounded mb-1">
          <p class="font-semibold">${i + 1}. ${s.name} × ${s.qty}</p>
          <p>Total: ₦${s.price * s.qty}</p>
          <p class="text-sm text-gray-600">
            Cash: ₦${s.payment.cash || 0},
            POS: ₦${s.payment.pos || 0},
            Bank: ₦${s.payment.bank || 0}
          </p>
        </div>
      `;
    });
  }
}

function setAuthIcon(loggedIn) {
  const btn = document.getElementById("authBtn");

  if (loggedIn) {
    btn.innerText = "🚪";
    btn.title = "Logout";
    btn.onclick = async () => {
      if (!confirm("Are you sure you want to logout?")) return;
      sessionStorage.removeItem("isAdmin");
      document.getElementById("userEmail").innerText = "";
      document.getElementById("admin").classList.add("hidden");
      cart = []; productData = []; soldData = [];
      try {
        await auth.signOut();
        window.location.replace("firebase login.html");
      } catch (err) {
        toast("Logout failed", true);
        console.error(err);
      }
    };
  } else {
    btn.innerText = "🔑";
    btn.title = "Login";
    btn.onclick = () => { window.location.href = "firebase login.html"; };
  }
}

/* ==============================
   FIREBASE DATA FUNCTIONS
============================== */
async function saveToFirebase(){
  if(!userUID) return;
  const ref = db.ref("users/" + userUID);
  await ref.set({
    companyName: clientCompanyName,
    products: productData,
    cart: cart,
    sold: soldData,
    adminPinHash: adminPinHash,
    resetCodeHash: resetCodeHash,
    resetCodeExpiry: resetCodeExpiry
  });
}

async function loadFromFirebase(){
  if(!userUID) return;
  const ref = db.ref("users/" + userUID);
  const snapshot = await ref.get();
  if(snapshot.exists()){
    const data = snapshot.val();
    clientCompanyName = data.companyName || "My Company";
    document.getElementById('companyName').innerText = clientCompanyName;
    productData = data.products || [];
    cart = data.cart || [];
    soldData = data.sold || [];
    adminPinHash = data.adminPinHash || null;
    resetCodeHash = data.resetCodeHash || null;
    resetCodeExpiry = data.resetCodeExpiry || null;
  } else {
    document.getElementById('companyName').innerText = clientCompanyName;
  }
}

/* =====================================================
   RENDER & CART FUNCTIONS
===================================================== */
const productListEl = document.getElementById('productList');
const cartItemsEl = document.getElementById('cartItems');
const searchProd = document.getElementById('searchProd');
const cartBtn = document.getElementById('cartBtn');
const closeCart = document.getElementById('closeCart');
const checkoutBtn = document.getElementById('checkoutBtn');
const checkoutModal = document.getElementById('checkoutModal');
const orderSummary = document.getElementById('orderSummary');
const closeCheckout = document.getElementById('closeCheckout');
const confirmOrder = document.getElementById('confirmOrder');
const cashPay = document.getElementById('cashPay');
const posPay = document.getElementById('posPay');
const bankPay = document.getElementById('bankPay');

function renderProducts(search=''){
  productListEl.innerHTML='';
  productData.filter(p=>p.name.toLowerCase().includes(search.toLowerCase()))
  .forEach((p,i)=>{
    productListEl.innerHTML += `
    <div class="bg-white shadow p-4 rounded-lg">
      <h3 class="font-semibold">${p.name} ${p.qty<=5?`<span class="low-stock">(Low Stock: ${p.qty})</span>`:''}</h3>
      <p class="text-red-600 font-bold">₦${p.price}</p>
      <p class="text-sm">Stock: ${p.qty}</p>
      <div class="flex justify-between mt-2">
        <button onclick="adjustQty(${i},-1)" class="px-2 bg-gray-200 rounded">-</button>
        <span id="qty${i}">1</span>
        <button onclick="adjustQty(${i},1)" class="px-2 bg-gray-200 rounded">+</button>
      </div>
      <button onclick="addToCart(${i})" class="bg-gradient-to-r from-red-500 to-red-700 text-white w-full py-2 rounded mt-2">Add to Cart</button>
    </div>`;
  });
}

function renderAdminProducts() {
  const adminList = document.getElementById("adminProductList");
  adminList.innerHTML = "";

  if(productData.length === 0){
    adminList.innerHTML = "<p class='text-gray-600'>No products yet</p>";
    return;
  }

  productData.forEach((p,i)=>{
    adminList.innerHTML += `
      <div class="flex items-center gap-2 bg-white p-2 rounded shadow">
        <input type="text" value="${p.name}" class="border p-1 rounded w-32" onchange="updateName(${i}, this.value)">
        <button onclick="changeQty(${i}, -1)" class="bg-gray-300 px-2 rounded">-</button>
        <span id="adminQty${i}" class="w-8 text-center">${p.qty}</span>
        <button onclick="changeQty(${i}, 1)" class="bg-gray-300 px-2 rounded">+</button>
        <input type="number" value="${p.price}" class="border p-1 rounded w-24" onchange="updatePrice(${i}, this.value)">
        <button onclick="deleteProduct(${i})" class="bg-red-600 text-white px-2 py-1 rounded">Delete</button>
      </div>
    `;
  });
}

function updateName(idx, val){
  if(!val) return toast("Name cannot be empty", true);
  productData[idx].name = val;
  saveToFirebase(); renderProducts(); renderAdminProducts();
}

function updatePrice(idx, val){
  val = parseFloat(val);
  if(isNaN(val) || val < 0) return toast("Invalid price", true);
  productData[idx].price = val;
  saveToFirebase(); renderProducts(); renderAdminProducts();
}

function changeQty(idx, val){
  productData[idx].qty += val;
  if(productData[idx].qty < 0) productData[idx].qty = 0;
  document.getElementById("adminQty"+idx).innerText = productData[idx].qty;
  saveToFirebase(); renderProducts();
}

function deleteProduct(idx){
  if(confirm("Are you sure you want to delete this product?")){
    productData.splice(idx,1);
    saveToFirebase(); renderProducts(); renderAdminProducts();
  }
}

function adjustQty(idx,val){
  const el=document.getElementById('qty'+idx);
  let qty=parseInt(el.innerText)+val;
  if(qty<1) qty=1;
  el.innerText=qty;
}

function addToCart(idx){
  const qtySel = +document.getElementById('qty'+idx).innerText;
  if(qtySel>productData[idx].qty) return toast("Not enough stock", true);
  cart.push({...productData[idx], qty: qtySel});
  updateCartUI();
  toast(`${productData[idx].name} added to cart`);
}

function updateCartUI(){
  cartItemsEl.innerHTML='';
  let total=0;
  cart.forEach((p,index)=>{
    total+=p.price*p.qty;
    cartItemsEl.innerHTML+=`
    <div class="flex justify-between items-center bg-gray-100 p-2 rounded">
      <div>
        <p class="font-semibold">${p.name} x${p.qty}</p>
        <p class="text-sm text-gray-600">₦${p.price*p.qty}</p>
      </div>
      <button onclick="removeFromCart(${index})" class="text-red-600 text-xl hover:scale-110 transition">❌</button>
    </div>`;
  });
  document.getElementById('cartTotal').innerText=total;
  document.getElementById('cartCount').innerText=cart.length;
  saveToFirebase();
}

function removeFromCart(index){ cart.splice(index,1); updateCartUI(); saveToFirebase(); }

/* =====================================================
   ADD PRODUCT (admin-gated)
===================================================== */
function doAddProduct(){
  const name = document.getElementById('prodName').value;
  const price = +document.getElementById('prodPrice').value;
  const qty = +document.getElementById('prodQty').value;
  if(!name || !price || !qty) return toast("Fill all fields", true);
  productData.push({name,price,qty});
  document.getElementById('prodName').value='';
  document.getElementById('prodPrice').value='';
  document.getElementById('prodQty').value='1';
  saveToFirebase(); renderProducts(); renderAdminProducts();
  toast(`${name} added.`);
}

document.getElementById('addProductForm').onsubmit = e => {
  e.preventDefault();
  if(sessionStorage.getItem('isAdmin') === 'true'){
    doAddProduct();
  } else {
    pendingAdminAction = doAddProduct;
    if(adminPinHash) showPinModal('enter'); else showPinModal('create');
  }
};

/* = SEARCH = */
searchProd.oninput=e=>renderProducts(e.target.value);

/* ====== MODALS ===*/
cartBtn.onclick=()=>document.getElementById('cartModal').style.display='flex';
closeCart.onclick=()=>document.getElementById('cartModal').style.display='none';

checkoutBtn.onclick=()=>{
  document.getElementById('cartModal').style.display='none';
  let summary='', total=0;
  cart.forEach(i=>{summary+=`${i.name} x${i.qty} - ₦${i.price*i.qty}\n`; total+=i.price*i.qty;});
  orderSummary.value = summary + `Total: ₦${total}`;
  checkoutModal.style.display='flex';
};
closeCheckout.onclick=()=>checkoutModal.style.display='none';

confirmOrder.onclick = () => {
  const cash = +cashPay.value || 0,
    pos = +posPay.value || 0,
    bank = +bankPay.value || 0;
  const paid = cash + pos + bank;
  const total = cart.reduce((a, p) => a + p.price * p.qty, 0);
  if (paid < total) return toast("Incomplete payment", true);

  const today = new Date().toISOString().split('T')[0];

  cart.forEach(c => {
    const idx = productData.findIndex(p => p.name === c.name);
    if (idx !== -1) productData[idx].qty -= c.qty;
    soldData.push({ ...c, date: today, payment: { cash, pos, bank } });
  });

  cart = [];
  updateCartUI();
  renderProducts();
  checkoutModal.style.display = 'none';
  saveToFirebase();
  toast("Sale completed ✅");
};

/* ==============================
   PRINT AND EXPORT FUNCTIONS
============================== */
function printHistory() {
  if (soldData.length === 0) return toast("No sales to print.", true);

  const grouped = soldData.reduce((acc, s) => {
    acc[s.date] = acc[s.date] || [];
    acc[s.date].push(s);
    return acc;
  }, {});

  let printContent = `
    <html>
    <head>
      <title>Sales History</title>
      <style>
        body { font-family: Arial, sans-serif; padding: 20px; color: #333; }
        h1 { text-align: center; font-size: 28px; font-weight: bold; margin-bottom: 10px; }
        h2 { margin-top: 40px; border-bottom: 2px solid #333; padding-bottom: 5px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #999; padding: 8px; text-align: left; }
        th { background-color: #f4f4f4; }
        tr:nth-child(even) { background-color: #f9f9f9; }
        tfoot td { font-weight: bold; background-color: #cbd5e1; font-size: 1.1em; }
      </style>
    </head>
    <body>
      <h1>${clientCompanyName}</h1>
      <h1>Sales History Report</h1>
  `;

  for (const date in grouped) {
    printContent += `<h2>Date: ${date}</h2>`;
    printContent += `
      <table>
        <thead>
          <tr>
            <th>#</th><th>Product</th><th>Quantity</th><th>Total (₦)</th>
            <th>Cash (₦)</th><th>POS (₦)</th><th>Bank (₦)</th>
          </tr>
        </thead>
        <tbody>
    `;

    let grandTotal = 0, totalCash = 0, totalPOS = 0, totalBank = 0;

    grouped[date].forEach((s, i) => {
      const total = s.price * s.qty;
      grandTotal += total;
      totalCash += s.payment.cash || 0;
      totalPOS += s.payment.pos || 0;
      totalBank += s.payment.bank || 0;

      printContent += `
        <tr>
          <td>${i + 1}</td><td>${s.name}</td><td>${s.qty}</td><td>${total}</td>
          <td>${s.payment.cash || 0}</td><td>${s.payment.pos || 0}</td><td>${s.payment.bank || 0}</td>
        </tr>
      `;
    });

    printContent += `
        </tbody>
        <tfoot>
          <tr style="background-color: #94a3b8; color: #fff; font-weight: bold; font-size: 1.1em;">
            <td colspan="3">Grand Total</td>
            <td>${grandTotal}</td><td>${totalCash}</td><td>${totalPOS}</td><td>${totalBank}</td>
          </tr>
        </tfoot>
      </table>`;
  }

  printContent += `</body></html>`;

  const printWindow = window.open('', '', 'height=600,width=900');
  printWindow.document.write(printContent);
  printWindow.document.close();
  printWindow.print();
}

function exportExcel() {
  if (soldData.length === 0) return toast("No sales to export.", true);

  const grouped = soldData.reduce((acc, s) => {
    acc[s.date] = acc[s.date] || [];
    acc[s.date].push(s);
    return acc;
  }, {});

  let csv = `${clientCompanyName}\n\n`;
  csv += 'Date,Product,Quantity,Total,Cash,POS,Bank\n';

  for (const date in grouped) {
    let grandTotal = 0, totalCash = 0, totalPOS = 0, totalBank = 0;

    grouped[date].forEach(s => {
      const total = s.price * s.qty;
      grandTotal += total;
      totalCash += s.payment.cash || 0;
      totalPOS += s.payment.pos || 0;
      totalBank += s.payment.bank || 0;

      csv += `${date},${s.name},${s.qty},${total},${s.payment.cash || 0},${s.payment.pos || 0},${s.payment.bank || 0}\n`;
    });

    csv += `${date},Grand Total,,${grandTotal},${totalCash},${totalPOS},${totalBank}\n\n`;
  }

  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.setAttribute("href", url);
  link.setAttribute("download", "sales_history.csv");
  link.style.display = "none";
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}

